# Zkopiruj na .env a vypln. V GitHub Actions vloz tyto hodnoty do Settings > Secrets.

# --- Gemini (scenar) ---
GEMINI_API_KEY=

# --- Affiliate / Invia XML feed (Krok 1) ---
# Vyber feed: bomby (nejvetsi slevy) | nejpro (nejprodavanejsi) | zakladni (last minute)
FEED=bomby
# AFFILIATE_API_URL se pouzije jen pokud chces vlastni URL misto FEEDS v kodu
AFFILIATE_API_URL=
AFFILIATE_API_KEY=

# --- TTS ---
VOICE=cs-CZ-AntoninNeural

# --- TikTok Content Posting API (Krok 5) ---
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_REFRESH_TOKEN=

# --- Rezim behu ---
# USE_SAMPLE_OFFER=1  -> ignoruje affiliate API, pouzije ukazkovou nabidku (pro test)
USE_SAMPLE_OFFER=1
# PUBLISH=0 -> jen vyrenderuje .mp4 do output/, nepublikuje
PUBLISH=0
