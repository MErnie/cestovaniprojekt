# Zkopiruj na .env a vypln. V GitHub Actions vloz tyto hodnoty do Settings > Secrets.

# --- Scenar (LLM) ---
# Priorita: GEMINI_API_KEY (primy, free tier) -> OpenRouter -> template
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemma-4-31b-it

# --- Affiliate / Invia XML feed (Krok 1) ---
# Vyber feed: bomby (nejvetsi slevy) | nejpro (nejprodavanejsi) | zakladni (last minute)
FEED=bomby
# AFFILIATE_API_URL se pouzije jen pokud chces vlastni URL misto FEEDS v kodu
AFFILIATE_API_URL=
AFFILIATE_API_KEY=

# Vyber nabidky
SELECT_MODE=discount           # discount = vzdy nejvetsi sleva | random = nahodne z TOP
ROTATE=0                        # 0 = vzdy nejlepsi (i opakovane) | 1 = neopakovat
DEST_FILTER=                    # napr. Chorvatsko (prazdne = vse)

# --- Hlas ---
TTS_PROVIDER=elevenlabs        # elevenlabs | edge (prazdne = edge)
VOICE=cs-CZ-AntoninNeural      # edge-tts fallback hlas (cs-CZ-VlastaNeural = zensky)
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL=eleven_multilingual_v2

# --- Stock fotky / video (Pexels, zdarma) ---
PEXELS_API_KEY=
USE_VIDEO_BG=1                 # 1 = video pozadi (b-roll), 0 = jen foto + Ken Burns

# --- Hudba ---
MUSIC_VOLUME=0.12

# --- TikTok Content Posting API (Krok 5) ---
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_REFRESH_TOKEN=

# --- Rezim behu ---
# USE_SAMPLE_OFFER=1  -> ignoruje affiliate API, pouzije ukazkovou nabidku (pro test)
USE_SAMPLE_OFFER=1
# PUBLISH=0 -> jen vyrenderuje .mp4 do output/, nepublikuje
PUBLISH=0
